<launch>
  <arg name="pcd_path" default="/home/aaaalien/rmua_ws/scans.pcd"/>
  <arg name="frame_id" default="world"/>
  <arg name="odom_topic" default="/eskf_odom"/>
  <arg name="path_topic" default="/planning/path"/>
  <arg name="cmd_topic" default="/airsim_node/drone_1/vel_body_cmd"/>

  <rosparam command="load" file="$(find ego_bridge)/config/ego_bridge.yaml"/>

  <node pkg="imu_gps_odometry" type="imu_gps_odometry" name="imu_gps_odometry" output="screen"/>

  <node pkg="ego_bridge" type="pcd_map_publisher" name="pcd_map_publisher" output="screen">
    <param name="pcd_path" value="$(arg pcd_path)"/>
    <param name="frame_id" value="$(arg frame_id)"/>
  </node>

  <node pkg="ego_bridge" type="path_to_vel_cmd" name="path_to_vel_cmd" output="screen">
    <param name="odom_topic" value="$(arg odom_topic)"/>
    <param name="path_topic" value="$(arg path_topic)"/>
    <param name="cmd_topic" value="$(arg cmd_topic)"/>
  </node>

  <!--
  After you add ego-planner into this workspace, include its launch here and
  remap its map input to /map_generator/global_cloud and odom input to /eskf_odom.
  Its planned path should be bridged or remapped to /planning/path.
  -->
</launch>
